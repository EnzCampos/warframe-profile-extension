{
  "manifest_version": 3,
  "name": "Warframe Profile Extension",
  "description": "Open source Warframe profile sync extension made for Warframe Tracker.",
  "version": "0.1.1",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Warframe Profile Extension"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "ids": ["*"],
    "matches": [
      "https://wf-tracker.com/*"
    ]
  },
  "host_permissions": [
    "https://www.warframe.com/*",
    "https://api.warframe.com/*",
    "http://content-ps4.warframe.com/*",
    "http://content-xb1.warframe.com/*",
    "http://content-swi.warframe.com/*",
    "http://content-mob.warframe.com/*",
    "http://content-and.warframe.com/*"
  ],
  "permissions": ["cookies", "storage"],
  "options_page": "options.html"
}
